    {
      "name": "visualstudio-build-debug-arm64",
      "displayName": "Build: Debug - Visual Studio - ARM64",
      "configurePreset": "visualstudio-debug-arm64",
      "configuration": "Debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
